# Update only these 3 IPs for your LAN
GW_HOST=192.168.1.10
AS_HOST=192.168.1.20
NODE_HOST=192.168.1.30

# SSH users are optional; defaults to pi in sync/orchestrate scripts
GW_USER=
AS_USER=
NODE_USER=

# Directory where this project will live on each machine
REMOTE_BASE_DIR=$HOME/mtp-hardware
PROJECT_DIR_NAME=Hardware

# Role ports (change if needed)
GW_PORT=5683
AS_PORT=5684
NODE_PORT=5685

# Bind addresses (0.0.0.0 is recommended)
GW_BIND=0.0.0.0
AS_BIND=0.0.0.0
NODE_BIND=0.0.0.0

# Device profile for native node runtime
DEVICE_ID=81
DEVICE_SECRET=device-secret-81
NODE_SEND_COUNT=10
NODE_SEND_INTERVAL_S=3

# PUF configuration for pypuf-based authentication
PUF_SEED=puf-seed-81
PUF_CHALLENGE_BITS=64
PUF_ENROLL_CRP_COUNT=64
FRESHNESS_WINDOW_S=120
